# PostgreSQL (docker compose up -d postgres)
DATABASE_URL="postgresql://pathlogs:pathlogs@localhost:5433/pathlogs"

# Auth.js: любая случайная строка 32+ символов (npx auth secret)
AUTH_SECRET="change-me-to-a-long-random-string"
AUTH_TRUST_HOST="true"

# S3-совместимое хранилище (AWS S3 / Cloudflare R2 / MinIO).
# При пустых значениях файлы сохраняются локально в ./uploads
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""
S3_ENDPOINT=""
S3_PUBLIC_URL=""
