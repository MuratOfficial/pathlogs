# =========================================================================
# Локальная разработка (docker compose up -d postgres)
# =========================================================================
DATABASE_URL="postgresql://pathlogs:pathlogs@localhost:5433/pathlogs"
# Прямое соединение для миграций. Локально совпадает с DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://pathlogs:pathlogs@localhost:5433/pathlogs"

# =========================================================================
# Production (Neon PostgreSQL) — задайте в .env.production или в переменных
# окружения хостинга. DATABASE_URL — пул соединений (-pooler),
# DATABASE_URL_UNPOOLED — прямое соединение (без -pooler) для миграций.
# Пример:
#   DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require"
#   DATABASE_URL_UNPOOLED="postgresql://USER:PASS@ep-xxx.REGION.aws.neon.tech/DB?sslmode=require"
# =========================================================================

# Сгенерируйте свой секрет: `openssl rand -base64 32`
AUTH_SECRET="YmuLkwqdt5uZPVeptISM2QFTAkSo20yxU6saILkhhd8="
AUTH_TRUST_HOST="true"

# S3-совместимое хранилище (AWS S3 / Cloudflare R2 / MinIO).
# При пустых значениях файлы сохраняются локально в ./uploads
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_REGION=""
S3_ENDPOINT=""
S3_PUBLIC_URL=""
